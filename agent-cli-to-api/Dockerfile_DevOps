FROM python:3.13-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1 \
	KUBECTL_VERSION=v1.32.3

RUN apt-get update && \
	DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
	  bash \
	  ca-certificates \
	  curl \
	  git && \
	apt-get clean && \
	rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Install Cursor CLI. The binary is exposed as `agent`.
RUN curl https://cursor.com/install -fsS | bash

# Install kubectl for DevOps workflows.
RUN set -eux; \
	arch="$(dpkg --print-architecture)"; \
	case "$arch" in \
	  amd64) kubectl_arch='amd64' ;; \
	  arm64) kubectl_arch='arm64' ;; \
	  *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; \
	esac; \
	curl -fsSLo /usr/local/bin/kubectl "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${kubectl_arch}/kubectl"; \
	chmod +x /usr/local/bin/kubectl

ENV PATH="/root/.local/bin:${PATH}" \
	CURSOR_AGENT_BIN=/usr/local/bin/cursor-agent-no-max

WORKDIR /app

COPY requirements.txt ./requirements.txt
RUN pip install --no-cache-dir --upgrade pip && \
	pip install --no-cache-dir -r requirements.txt

COPY . .

RUN chmod +x /app/cursor-agent-no-max.sh && \
	ln -sf /app/cursor-agent-no-max.sh /usr/local/bin/cursor-agent-no-max

# Install local package so `agent-cli-to-api` entrypoint is available.
RUN pip install --no-cache-dir .

EXPOSE 8000

# Cursor-first defaults (override with docker run -e ... when needed)
ENV CODEX_PROVIDER=cursor-agent \
	CURSOR_AGENT_MODEL=auto \
	CURSOR_AGENT_DISABLE_INDEXING=1 \
	CODEX_MAX_PROMPT_CHARS=60000

CMD ["agent-cli-to-api", "cursor-agent", "--host", "0.0.0.0", "--port", "8000"]
