# Keep Docker build context small. The source is freshly cloned in CI,
# but these paths can be generated by local/dev workflows and should not
# invalidate cache or get uploaded to BuildKit.
.git
.github
**/.git
**/.turbo
**/.next
**/.cache
**/node_modules
**/dist
**/build
**/coverage
**/*.log
apps/android/.gradle
apps/android/app/build
