FROM node:24-bookworm

ENV KUBECTL_VERSION=v1.32.3
ENV HELM_VERSION=v3.17.3
ENV PLAYWRIGHT_VERSION=1.59.1

RUN --mount=type=cache,id=openclaw-bookworm-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=openclaw-bookworm-apt-lists,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      hostname \
      lsof \
      openssl \
      procps \
      python3 \
      tini \
      tmux \
      unzip && \
    update-ca-certificates

# Install Bun (required for build scripts)
RUN curl -fsSL https://bun.sh/install | bash

ENV PATH="/root/.local/bin:/root/.bun/bin:${PATH}" \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    OPENCLAW_PREFER_PNPM=1

RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) kubectl_arch='amd64' ;; \
      arm64) kubectl_arch='arm64' ;; \
      *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSLo /usr/local/bin/kubectl "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${kubectl_arch}/kubectl"; \
    chmod +x /usr/local/bin/kubectl; \
    helm_arch="${kubectl_arch}"; \
    curl -fsSL "https://get.helm.sh/helm-${HELM_VERSION}-linux-${helm_arch}.tar.gz" -o /tmp/helm.tar.gz; \
    tar -xzf /tmp/helm.tar.gz -C /tmp; \
    mv "/tmp/linux-${helm_arch}/helm" /usr/local/bin/helm; \
    chmod +x /usr/local/bin/helm; \
    rm -rf /tmp/helm.tar.gz "/tmp/linux-${helm_arch}"

# Install AWS CLI v2
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) aws_arch='x86_64' ;; \
      arm64) aws_arch='aarch64' ;; \
      *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSLo awscliv2.zip "https://awscli.amazonaws.com/awscli-exe-linux-${aws_arch}.zip"; \
    unzip awscliv2.zip; \
    ./aws/install; \
    rm -rf awscliv2.zip ./aws

RUN corepack enable

# Install Playwright as a Node.js library only – no browser binaries.
# We attach to a remote Chromium via connectOverCDP and never launch local
# browsers, so browser binaries and their apt deps (libnss3, libatk*, libgbm1
# etc.) are intentionally skipped.
RUN --mount=type=cache,target=/root/.npm PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npm install -g playwright@${PLAYWRIGHT_VERSION} \
  && npx playwright --version

# Let CommonJS require('playwright') resolve from any cwd (agent scripts may
# run under /root/.openclaw/workspace-*, /tmp, etc.).
ENV NODE_PATH=/usr/local/lib/node_modules

WORKDIR /app

ARG OPENCLAW_DOCKER_APT_PACKAGES=""
RUN --mount=type=cache,id=openclaw-bookworm-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=openclaw-bookworm-apt-lists,target=/var/lib/apt,sharing=locked \
    if [ -n "$OPENCLAW_DOCKER_APT_PACKAGES" ]; then \
      apt-get update && \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends $OPENCLAW_DOCKER_APT_PACKAGES; \
    fi

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY ui/package.json ./ui/package.json
COPY patches ./patches
COPY scripts ./scripts

RUN --mount=type=cache,id=openclaw-pnpm-store,target=/root/.local/share/pnpm/store,sharing=locked \
    NODE_OPTIONS=--max-old-space-size=2048 pnpm install --frozen-lockfile \
      --config.supportedArchitectures.os=linux \
      --config.supportedArchitectures.cpu="$(node -p 'process.arch')" \
      --config.supportedArchitectures.libc=glibc

# pnpm install --frozen-lockfile wipes /app/node_modules entries that are not
# declared in pnpm-lock.yaml, so we must create these symlinks AFTER pnpm
# installs. This is what makes ESM `import 'playwright'` resolve when
# running from /app without adding playwright to the project's package.json.
RUN ln -sf /usr/local/lib/node_modules/playwright      /app/node_modules/playwright \
 && ln -sf /usr/local/lib/node_modules/playwright-core /app/node_modules/playwright-core \
 && node -e "const {chromium}=require('playwright'); if(typeof chromium.connectOverCDP!=='function') process.exit(1); console.log('playwright ok', require('playwright/package.json').version)"

COPY . .

# Match upstream docker build path instead of the generic dev build.
RUN OPENCLAW_A2UI_SKIP_MISSING=1 pnpm_config_verify_deps_before_run=false pnpm canvas:a2ui:bundle || \
    (echo "A2UI bundle: creating stub (non-fatal)" && \
     mkdir -p extensions/canvas/src/host/a2ui && \
     echo "/* A2UI bundle unavailable in this build */" > extensions/canvas/src/host/a2ui/a2ui.bundle.js && \
     echo "stub" > extensions/canvas/src/host/a2ui/.bundle.hash && \
     rm -rf vendor/a2ui apps/shared/OpenClawKit/Tools/CanvasA2UI)
RUN NODE_OPTIONS=--max-old-space-size=8192 pnpm_config_verify_deps_before_run=false node scripts/tsdown-build.mjs && echo "tsdown-build completed"
RUN pnpm_config_verify_deps_before_run=false node scripts/check-cli-bootstrap-imports.mjs && echo "check-cli-bootstrap-imports completed"
RUN pnpm_config_verify_deps_before_run=false node scripts/runtime-postbuild.mjs && echo "runtime-postbuild completed"
RUN pnpm_config_verify_deps_before_run=false node scripts/build-stamp.mjs && echo "build-stamp completed"
RUN pnpm_config_verify_deps_before_run=false node scripts/runtime-postbuild-stamp.mjs && echo "runtime-postbuild-stamp completed"
RUN pnpm_config_verify_deps_before_run=false pnpm plugins:assets:build && echo "plugins:assets:build completed"
RUN pnpm_config_verify_deps_before_run=false pnpm plugins:assets:copy && echo "plugins:assets:copy completed"
RUN pnpm_config_verify_deps_before_run=false node --experimental-strip-types scripts/copy-hook-metadata.ts && echo "copy-hook-metadata completed"
RUN pnpm_config_verify_deps_before_run=false node --experimental-strip-types scripts/copy-export-html-templates.ts && echo "copy-export-html-templates completed"
RUN pnpm_config_verify_deps_before_run=false node --experimental-strip-types scripts/write-build-info.ts && echo "write-build-info completed"
RUN sed -i 's/const BROWSER_HELP_RENDER_TIMEOUT_MS = 120_000;/const BROWSER_HELP_RENDER_TIMEOUT_MS = 300_000;/' scripts/write-cli-startup-metadata.ts && \
    pnpm_config_verify_deps_before_run=false node --experimental-strip-types scripts/write-cli-startup-metadata.ts && echo "write-cli-startup-metadata completed"
RUN pnpm_config_verify_deps_before_run=false node --experimental-strip-types scripts/write-cli-compat.ts && echo "write-cli-compat completed"
RUN pnpm_config_verify_deps_before_run=false pnpm ui:build && echo "ui pnpm ui:build completed"
RUN pnpm_config_verify_deps_before_run=false pnpm qa:lab:build && echo "qa lab build completed"
RUN echo "Dockerfile build steps completed"

RUN ln -sf /app/openclaw.mjs /usr/local/bin/openclaw && \
    chmod 755 /app/openclaw.mjs && \
    install -d -m 0700 /root/.openclaw

ENV NODE_ENV=production

# Run as root for full container privileges
HEALTHCHECK --interval=3m --timeout=10s --start-period=15s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:18789/healthz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
ENTRYPOINT ["tini", "-s", "--"]
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
